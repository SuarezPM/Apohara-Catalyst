{
	"name": "apohara",
	"version": "2.0.0-alpha",
	"module": "index.ts",
	"type": "module",
	"main": "dist/cli.js",
	"bin": {
		"apohara": "./dist/cli.js"
	},
	"files": [
		"dist",
		"binaries",
		"scripts"
	],
	"scripts": {
		"postinstall": "node scripts/postinstall.js",
		"build": "bun build src/cli.ts --target node --outdir dist",
		"start": "bun run src/cli.ts",
		"generate-types": "cargo run --bin generate_types --features ts-export -- packages/apohara-shared",
		"generate-types:check": "bun run generate-types && git diff --exit-code packages/apohara-shared/types.ts"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@playwright/test": "^1.60.0",
		"@types/bun": "latest",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"zod": "^4.4.1"
	}
}
